# Environment variables for FreelancerPro

# production | development
EXPO_PUBLIC_APP_ENV=production

# Laravel API base URL (no trailing slash)
# Local: http://127.0.0.1:8000
# Production: https://api.yourdomain.com
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000
# Web app URL for Zibal payment callback (optional — defaults to current browser URL)
EXPO_PUBLIC_WEB_APP_URL=http://localhost:8081

# Cafe Bazaar RSA public key (from پنل توسعه‌دهندگان بازار)
EXPO_PUBLIC_BAZAAR_RSA_KEY=
